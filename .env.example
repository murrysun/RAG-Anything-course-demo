LLM_BINDING_API_KEY=请填写自己的DeepSeek_API_Key
LLM_BINDING_HOST=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled

OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBED_CONCURRENCY=1
OLLAMA_KEEP_ALIVE=60m

PARSER=mineru
PARSE_METHOD=auto
MINERU_MODEL_SOURCE=local

OUTPUT_DIR=./output
WORKING_DIR=./rag_storage_demo

ENABLE_IMAGE_PROCESSING=false
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true

MINERU_PROCESSING_WINDOW_SIZE=4
MINERU_HYBRID_BATCH_RATIO=1
MINERU_API_MAX_CONCURRENT_REQUESTS=1
MINERU_PDF_RENDER_THREADS=1

TEMPERATURE=0
MAX_TOKENS=4096
TIMEOUT=240